# Tara — environment template. Copy to .env and fill in. NEVER commit .env.
#
# The app boots with this file as-is: every external integration defaults to a
# mock (MOCK_*=true), so no API keys are required to run locally. Set a MOCK_*
# flag to false and provide the matching credentials to use the real service.

# App
APP_ENV=development
PORT=3000

# Database (PostgreSQL) — async driver. Leave blank to use a local SQLite file.
# Any of these forms works; postgres://... and postgresql://... are auto-upgraded
# to the asyncpg driver. Missing tables are created automatically on app startup.
#   DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tara
DATABASE_URL=

# Document store (MongoDB) — chat history + durable memory.
# Set MOCK_MONGO=false and run a local mongod to enable persistence.
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=tara
MOCK_MONGO=true

# Vector DB (ChromaDB) — host/port of the Chroma server
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Cache / queue (Redis — broker + result backend for Celery)
REDIS_URL=redis://localhost:6379/0

# LLM (OpenAI)
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
# Embedding model for the knowledge RAG dense (vector) retriever.
EMBEDDING_MODEL=text-embedding-ada-002

# Ephemeris / charts (hosted astrology API)
EPHEMERIS_API_URL=
EPHEMERIS_API_KEY=

# WhatsApp BSP (Gupshup / Wati / Twilio) + Channel
WHATSAPP_BSP_PROVIDER=gupshup
WHATSAPP_BSP_API_KEY=
WHATSAPP_CHANNEL_ID=

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Geocoding / timezone (OpenCage / Google)
GEOCODING_API_KEY=

# ---- Mock switches (default true: run with no third-party credentials) ----
MOCK_OPENAI=true
MOCK_EPHEMERIS=true
MOCK_WHATSAPP=true
MOCK_RAZORPAY=true
MOCK_GEOCODING=true
MOCK_CHROMA=true
