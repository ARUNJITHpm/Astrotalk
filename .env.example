# Tara — environment template. Copy to .env and fill in. NEVER commit .env.

# App
APP_ENV=development
PORT=3000

# Database (PostgreSQL) — async driver
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tara

# Vector DB (ChromaDB) — host/port of the Chroma server
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Cache / queue
REDIS_URL=redis://localhost:6379

# LLM (OpenAI)
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini

# Ephemeris / charts (hosted astrology API)
EPHEMERIS_API_URL=
EPHEMERIS_API_KEY=

# WhatsApp BSP (Gupshup / Wati / Twilio)
WHATSAPP_BSP_API_KEY=
WHATSAPP_CHANNEL_ID=

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Geocoding / timezone
GEOCODING_API_KEY=
